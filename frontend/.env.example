# FarmSense AI — Frontend environment variables

# FarmSense FastAPI backend URL (used when mock mode is off)
VITE_API_BASE_URL=http://localhost:8000

# Set to "false" to use real backend instead of mock data
VITE_USE_MOCK_API=false

# Simulated network delay for mock responses (milliseconds)
VITE_MOCK_DELAY=600
