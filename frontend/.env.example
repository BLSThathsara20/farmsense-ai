# FarmSense AI — Frontend environment variables

# FarmSense FastAPI backend URL
VITE_API_BASE_URL=http://localhost:8000

# Live backend is the default. Set to "true" only for offline UI work without the API.
VITE_USE_MOCK_API=false

# Simulated network delay when mock mode is on (milliseconds)
VITE_MOCK_DELAY=600

# Reserved super-admin email (first-time register sets password)
VITE_SUPER_ADMIN_EMAIL=blsthathsara@gmail.com
